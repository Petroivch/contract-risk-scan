NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
PUBLIC_BASE_URL=https://api.contract-risk-scanner.local
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
SWAGGER_TITLE=Contract Risk Scanner Core API
SWAGGER_DESCRIPTION=MVP API for auth, contract upload and risk report retrieval
SWAGGER_VERSION=0.3.0
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=1h
TOKEN_TYPE=Bearer
ACCESS_TOKEN_TTL_SECONDS=3600
MAX_UPLOAD_SIZE_MB=25
ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain
DATA_DIR=.runtime/core-api-data
ANALYSIS_ENGINE_ENABLED=true
ANALYSIS_ENGINE_BASE_URL=http://127.0.0.1:8010
ANALYSIS_ENGINE_REQUEST_TIMEOUT_MS=15000
ANALYSIS_ENGINE_POLL_INTERVAL_MS=2000
ANALYSIS_ENGINE_MAX_POLLING_DURATION_MS=120000
