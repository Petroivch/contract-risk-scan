{
  "name": "contract-risk-scan-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "eas:build:ios:preview": "npx eas-cli@latest build --platform ios --profile preview",
    "eas:build:ios:production": "npx eas-cli@latest build --platform ios --profile production",
    "eas:submit:ios": "npx eas-cli@latest submit --platform ios --profile production",
    "lint": "eslint App.tsx src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "smoke:expo": "expo config --type public",
    "smoke:analysis": "node scripts/run-analysis-smoke.cjs",
    "smoke": "npm run smoke:expo && npm run smoke:analysis",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.2.3",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "expo": "~51.0.28",
    "expo-document-picker": "~12.0.2",
    "expo-file-system": "~17.0.1",
    "expo-sqlite": "~14.0.6",
    "i18next": "^23.15.2",
    "jszip": "^3.10.1",
    "pako": "^2.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-i18next": "^15.0.2",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-safe-area-context": "^4.10.5",
    "react-native-screens": "~3.31.1",
    "react-native-web": "~0.19.10",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "@types/react": "~18.2.79",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2"
  }
}
